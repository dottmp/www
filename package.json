		"@fontsource/ibm-plex-serif": "^5.2.7",
		"mdsvex-relative-images": "^2.0.0",
		"mode-watcher": "^1.1.0",
		"shiki": "^3.22.0",
		"tailwind-merge": "^3.5.0"
